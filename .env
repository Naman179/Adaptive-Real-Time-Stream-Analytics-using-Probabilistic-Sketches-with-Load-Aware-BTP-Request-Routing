# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=stream_events

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API
API_HOST=0.0.0.0
API_PORT=8000

# Controller thresholds
LATENCY_HIGH_MS=200
MEMORY_HIGH_PERCENT=80
ERROR_HIGH=0.05
CONTROLLER_INTERVAL_SEC=5

# Router weights (must sum to 1.0)
ROUTER_W1=0.5
ROUTER_W2=0.3
ROUTER_W3=0.2
